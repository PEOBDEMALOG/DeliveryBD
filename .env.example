# ── Banco de dados ──────────────────────────────────────────────────────────
# Não definir localmente para usar SQLite (não funciona no Vercel):
# DATABASE_URL=sqlite+aiosqlite:///data/db/peo_bd.db

# Supabase (Postgres) em produção/Vercel. SSL obrigatório é aplicado automaticamente
# pelo core/config.py (DB_CONNECT_ARGS) sempre que a URL for postgresql(+asyncpg).
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# ── E-mail (SMTP para programações às transportadoras) ──────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=expedicao@suaempresa.com
SMTP_PASSWORD=sua_senha_aqui
EMAIL_FROM=expedicao@suaempresa.com

# ── Alertas por e-mail (Resend — transacional, alertas internos Emalog) ──────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_ALERTAS_EMALOG=erick.antonio@emalog.com.br

# ── Claude AI (Assistente de Diagnóstico) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Obrigatório — a aplicação falha ao subir sem isso (core/config.py). Gere um
# valor único por ambiente, nunca reaproveite entre dev/teste/produção:
#   openssl rand -hex 32
JWT_SECRET=gere_um_valor_unico_com_openssl_rand_hex_32
